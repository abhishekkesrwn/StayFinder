<% layout("/layouts/boilerplate.ejs")%>

        <body>
                <div class="row row-cols-8">
                        <h2>Edit your listing</h2>
                        <br><br>
                        <form action="/listings/<%= selectedListing.id%>?_method=PUT" method="post" novalidate
                                class="needs-validation" enctype="multipart/form-data">
                                <div class="row">
                                        <div class="mb-3 col">
                                                <div class="mb-3 col"> <label for="title" class="form-label">Title
                                                                :</label>
                                                        <input class="form-control" name="listing[title]"
                                                                value="<%=selectedListing.title%>" id="title" required>
                                                        <div class="invalid-feedback">Please enter title</div>
                                                </div>
                                                <!-- description -->
                                                <div class="mb-3">
                                                        <label for="description" class="form-label">
                                                                Description:</label>
                                                        <textarea cols="70" name="listing[description]"
                                                                class="form-control" id="description"
                                                                required><%= selectedListing.description %></textarea>

                                                        <div class="invalid-feedback">Please enter description.</div>
                                                </div>
                                                <div class="mb-3 col"> <label for="price" class="form-label">Price
                                                                :</label>
                                                        <input name="listing[price]" type="number"
                                                                value="<%= selectedListing.price %>"
                                                                class="form-control" id="price" required>
                                                        <div class="invalid-feedback">Enter valid price.</div>
                                                </div>
                                        </div>
                                        <!-- image -->
                                        <div class="col">
                                                <div class="col mb-3 ">
                                                        <img src="<%= newImageUrl%>" alt="listing_image_to_be updated">
                                                </div>
                                                <div class="col align-self-end mb-3"> <label for="image"
                                                                class="form-label">Upload a new image
                                                        </label>
                                                        <input class="form-control" type="file" name="listing[image]"
                                                                placeholder="Upload images" id="image">
                                                </div>
                                        </div>
                                </div>
                                <div class="row">
                                        <div class="mb-3 col"><label for="location" class="form-label"> Location :
                                                </label><input name="listing[location]"
                                                        value="<%= selectedListing.location %>" class="form-control"
                                                        type="text" required>
                                                <div class="invalid-feedback">Enter valid Location.</div>
                                        </div>

                                        <div class="mb-3 col"> <label for="country" class="form-label"> Country
                                                        :</label><input name="listing[country]"
                                                        value="<%= selectedListing.country %>" class="form-control"
                                                        required type="text">
                                                <div class="invalid-feedback">Enter valid Country.</div>
                                        </div>
                                </div>
                                <button class="btn update-btn mb-3 mt-3">Edit</button>
                        </form>
                </div>
        </body>