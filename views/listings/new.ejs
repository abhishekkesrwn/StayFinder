<% layout("/layouts/boilerplate.ejs") %>

    <body>
        <div class="row col-8">
            <h2>Create new Listing</h2>
            <br><br>
            <form action="/listings" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title<span class="text-danger">*</span></label>
                    <input class="form-control" id="title" type="text" name="listing[title]" placeholder="Enter Title"
                        required>
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Please enter title.</div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="description" name="listing[description]"
                        placeholder="Enter description" required></textarea>
                    <div class="invalid-feedback">Enter a short description</div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4"> <label for="price" class="form-label">Price<span
                                class="text-danger">*</span></label>
                        <input class="form-control" type="text" name="listing[price]" id="price"
                            placeholder="Enter price" required>
                        <div class="invalid-feedback">Enter a valid price.</div>
                    </div>
                    <div class="mb-3 col-md-8"> <label for="image" class="form-label">Upload an image<span
                                class="text-danger">*</span> </label>
                        <input class="form-control" type="file" name="listing[image]" placeholder="Upload images"
                            id="image" required>
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4"> <label for="location" class="form-label">Location<span
                                class="text-danger">*</span></label>
                        <input class="form-control" id="location" type="text" name="listing[location]"
                            placeholder="Enter location" required>
                        <div class="invalid-feedback">Location should be valid.</div>
                    </div>

                    <div class="mb-3 col-md-8"> <label for="country" class="form-label">Country<span
                                class="text-danger">*</span></label>
                        <input class="form-control" id="country" type="text" name="listing[country]"
                            placeholder="Enter country" required>
                        <div class="invalid-feedback">Country should be valid.</div>
                    </div>
                </div>
                <br><br>
                <button class="btn btn-dark mb-3 update-btn" type="submit">Add</button>
            </form>
        </div>

    </body>